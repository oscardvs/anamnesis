# Copy to ~/.config/anamnesis/dashboard.env and edit for this machine.

# PATH must include: the nvm node bin dir, ~/.local/bin (uv), and system dirs.
PATH=/home/YOU/.nvm/versions/node/v20.20.0/bin:/home/YOU/.local/bin:/usr/bin:/bin

# Absolute path to the server project so the dashboard can shell to the CLI.
ANAMNESIS_SERVER=/home/YOU/anamnesis/server

# This machine's stable id (defaults to hostname if unset).
ANAMNESIS_MACHINE_ID=odesha

# Git remote for sync (optional; omit for local-only).
# ANAMNESIS_GIT_REMOTE=you@host.tailnet.ts.net:anamnesis-memory.git

# Store root (optional; default ~/.anamnesis).
# ANAMNESIS_HOME=/home/YOU/.anamnesis
