# Anamnesis - example environment. Copy to .env (which is git-ignored) and fill in.
# Nothing here is required to read this file; defaults are sensible for local use.

# Where the local memory store + index live (default: ~/.anamnesis)
# ANAMNESIS_HOME=~/.anamnesis

# Machine-of-origin stamped on notes you write (default: this host's hostname).
# ANAMNESIS_MACHINE_ID=desktop-amsterdam

# Note: when Claude Code launches the MCP server it uses a filtered environment,
# so these vars are NOT inherited from your shell - set them in the server's
# "env" block in .mcp.json instead. This .env is for running tooling by hand.

# Git remote used to sync the markdown memory store across your machines.
# With Tailscale, this is typically an SSH path to another node or a small relay.
# ANAMNESIS_GIT_REMOTE=git@desktop.tailnet-name.ts.net:anamnesis-memory.git

# Reflection/compression model for the SessionEnd episodic summary (architecture
# section 6). Intentionally swappable - pick by current price/quality. Leave unset
# (or "heuristic") for the deterministic builder with no network call. Set a cloud
# provider to enable the LLM summarizer; if model/base-url/key are incomplete it
# silently falls back to heuristic so capture never breaks teardown.
# ANAMNESIS_REFLECTION_PROVIDER=heuristic   # heuristic | deepseek | openai | local
# ANAMNESIS_REFLECTION_MODEL=               # provider's model id, e.g. for DeepSeek
# ANAMNESIS_REFLECTION_BASE_URL=            # OpenAI-compatible base, e.g. https://api.deepseek.com
# ANAMNESIS_REFLECTION_TIMEOUT=30           # seconds; SessionEnd capture is inline
# ANAMNESIS_REFLECTION_MAX_TOKENS=120000    # transcript is windowed above this
# DEEPSEEK_API_KEY=
# Or a provider-neutral key: ANAMNESIS_REFLECTION_API_KEY=
