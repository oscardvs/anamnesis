# Anamnesis - example environment. Copy to .env (which is git-ignored) and fill in.
# Nothing here is required to read this file; defaults are sensible for local use.

# Where the local memory store + index live (default: ~/.anamnesis)
# ANAMNESIS_HOME=~/.anamnesis

# Git remote used to sync the markdown memory store across your machines.
# With Tailscale, this is typically an SSH path to another node or a small relay.
# ANAMNESIS_GIT_REMOTE=git@desktop.tailnet-name.ts.net:anamnesis-memory.git

# Reflection/compression model used for the "sleep-time" summarization pass.
# The model is intentionally swappable - pick by current price/quality.
# ANAMNESIS_REFLECTION_PROVIDER=anthropic   # anthropic | deepseek | openai | local
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
